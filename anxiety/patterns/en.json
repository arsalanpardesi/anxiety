  ],
  "hallucination_patterns": [
    ["(?:\\d+|one|two|three|four|five|several|multiple)\\s+interviews?\\s+(?:were|was|conducted)", "claims interviews were conducted"],
    ["(?:we|our team|the team)\\s+(?:conducted|performed|held)\\s+(?:a\\s+)?(?:site\\s+visit|interview|workshop|survey)", "claims a visit/interview/workshop/survey was conducted"],
    ["management\\s+(?:confirmed|stated|indicated)\\s+(?:during|in)\\s+(?:our|the)\\s+(?:session|call|meeting|interview)", "claims management confirmed during a session"],
    ["(?:expert|management|stakeholder)\\s+(?:call|session|interview)\\s+(?:on|dated|of)\\s+\\d", "references a specific dated call/session"],
    ["(?:interviews?|discussions?|conversations?)\\s+with\\s+(?:key\\s+)?(?:management|personnel|staff|stakeholders|participants)", "claims interviews/discussions with people"],
    ["(?:physical|on-?site)\\s+(?:inspection|assessment|review|observation)\\s+(?:revealed|confirmed|showed|found)", "claims on-site inspection findings"],
    ["(?:we\\s+)?(?:observed|inspected|toured|visited)\\s+(?:the\\s+)?(?:plant|facility|site|office|premises)", "claims direct observation of a facility"],
    ["(?:our\\s+)?testing\\s+(?:confirmed|revealed|showed|demonstrated)", "claims testing was performed"],
    ["(?:a\\s+)?survey\\s+of\\s+\\d+\\s+(?:respondents?|participants?|customers?|users?)", "claims a quantified survey"]
  ],
  "scope_none_pattern": "(?:desk\\s+research\\s+only|no\\s+(?:interviews?|management\\s+access|site\\s+visits?|primary\\s+research)|access\\s*[:\\-]\\s*none|secondary\\s+sources\\s+only)",
