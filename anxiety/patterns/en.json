    "\\broughly\\b", "\\bgenerally\\b", "\\btypically\\b", "\\bsubstantially\\b",
    "\\bmostly\\b", "\\brelatively\\b", "\\bsomewhat\\b", "\\bfairly\\b"
  ],
  "deferred": [
    ["should\\s+be\\s+analy[sz]ed", "should be analyzed"],
    ["should\\s+be\\s+reviewed", "should be reviewed"],
    ["requires?\\s+further\\s+(?:analysis|investigation|review|work)", "requires further analysis"],
    ["could\\s+not\\s+(?:be\\s+)?(?:confirmed|verified|validated)", "could not be confirmed"],
    ["was\\s+not\\s+(?:available|provided|disclosed)", "was not available"],
    ["(?:insufficient|limited)\\s+(?:data|evidence|information)", "insufficient data"],
    ["to\\s+be\\s+(?:determined|confirmed)|\\bTBD\\b|\\bTBC\\b", "to be determined"]
  ],
  "citation_hint": "(?:source\\s*[:\\-]|ref\\s*[:\\-]|cite|citation|per\\s+the|according\\s+to|see\\s+(?:table|figure|appendix|section|exhibit)|\\[\\d+\\]|\\(\\d{4}\\)|et\\s+al\\.|https?://|footnote|endnote)",
  "superlative_pattern": "\\b(?:the\\s+)?(?:most|least|best|worst|highest|lowest|largest|smallest|strongest|weakest|fastest|slowest|leading)\\b",
  "superlative_qualifier_pattern": "benchmark|peer|comparator|sector|industry|quartile|median|percentile|compared\\s+to|relative\\s+to|versus|vs\\.?",
  "baseline_groups": {
