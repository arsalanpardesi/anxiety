  "direction_positive": [
    "\\bincreas(?:ed|ing)\\b", "\\bgr[eo]w(?:th|n|ing)?\\b", "\\bimproved?\\b",
    "\\brose\\b", "\\brising\\b", "\\bhigher\\b", "\\bup\\b"
