  "growth_context": "\\bgr(?:ew|ow(?:s|n|ing|th)?)\\b|\\bincreas(?:e|ed|ing)\\b|\\brose\\b|\\brising\\b|\\bCAGR\\b|\\bcompounded?\\b|\\byear[- ]over[- ]year\\b|\\bYoY\\b|\\bY/Y\\b|\\bmultiple\\b",
